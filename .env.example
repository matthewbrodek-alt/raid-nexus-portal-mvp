NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Firebase public web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional external forwarding for top-up/order requests.
# Leave empty if the site should use only the internal Firebase order desk.
TOPUP_WEBHOOK_URL=

# Server-side encryption and social auth
GAME_DATA_ENCRYPTION_KEY=
SOCIAL_AUTH_STATE_SECRET=
FIREBASE_SERVICE_ACCOUNT_EMAIL=
FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY=
TELEGRAM_BOT_TOKEN=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Public links
NEXT_PUBLIC_MANAGER_TELEGRAM_URL=
NEXT_PUBLIC_CRM_URL=
