rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(roles) {
      return signedIn() && profile().role in roles && profile().status == "active";
    }

    function activeUser() {
      return signedIn()
        && request.auth.token.email_verified == true
        && profile().status == "active"
        && (
          !exists(/databases/$(database)/documents/globalUserBlocks/$(request.auth.uid))
          || get(/databases/$(database)/documents/globalUserBlocks/$(request.auth.uid)).data.blockedUntil <= request.time
        );
    }

    function isAdmin() {
      return hasRole(["admin", "owner"]);
    }

    function isOwner() {
      return hasRole(["owner"]);
    }

    function userGroup(groupId) {
      return get(/databases/$(database)/documents/userGroups/$(groupId)).data;
    }

    function isUserGroupMember(groupId) {
      return signedIn()
        && (
          isAdmin()
          || groupId == request.auth.uid
          || userGroup(groupId).ownerUid == request.auth.uid
          || userGroup(groupId).get("memberUids", []).hasAny([request.auth.uid])
        );
    }

    function hasPendingAdminInvite() {
      return signedIn()
        && exists(/databases/$(database)/documents/adminInvites/$(request.auth.token.email))
        && get(/databases/$(database)/documents/adminInvites/$(request.auth.token.email)).data.status == "pending";
    }

    match /users/{uid} {
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && (
          request.resource.data.role == "user"
          || (request.resource.data.role == "admin" && hasPendingAdminInvite())
        );

      allow read: if signedIn();

      allow update: if signedIn() && (
        isOwner()
        || (
          isAdmin()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status",
            "avatarHiddenByAdmin",
            "totalSpentRub",
            "bpStatus",
            "bumpyCoinsBalance",
            "bumpyCoinsEarnedTotal",
            "bumpyCoinsSpentTotal",
            "updatedAt"
          ])
        )
        || (
          request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && !request.resource.data.diff(resource.data).changedKeys().hasAny(["avatarHiddenByAdmin"])
        )
        || (
          request.auth.uid == uid
          && resource.data.role == "user"
          && request.resource.data.role == "admin"
          && hasPendingAdminInvite()
        )
      );
    }

    match /adminInvites/{emailId} {
      allow read: if signedIn() && (isOwner() || emailId == request.auth.token.email);
      allow create: if isOwner() && request.resource.data.email == emailId;
      allow delete: if isOwner();
      allow update: if isOwner()
        || (
          signedIn()
          && resource.data.email == request.auth.token.email
          && resource.data.status == "pending"
          && request.resource.data.status == "accepted"
          && request.resource.data.acceptedBy == request.auth.uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["acceptedAt", "acceptedBy", "status"])
        );
    }

    match /encryptedGameAccounts/{uid} {
      allow read, write: if signedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /heroes/{heroId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    match /heroCalendar/{eventId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    match /portalOffers/{offerId} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow write: if isAdmin();
    }

    match /eventWidgets/{widgetId} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          activeUser()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["participants", "participantCount", "updatedAt"])
          && request.resource.data.participantCount == resource.data.participantCount + 1
          && !(request.auth.uid in resource.data.participants)
          && request.auth.uid in request.resource.data.participants
        );
    }

    match /donationOffers/{offerId} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow write: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow create: if activeUser()
        && request.resource.data.status == "published"
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 420
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }

    match /raffleEntries/{entryId} {
      allow get: if signedIn();
      allow list: if isAdmin();
      allow create: if activeUser()
        && request.resource.data.uid == request.auth.uid
        && entryId == request.auth.uid + "_" + request.resource.data.drawKey;
      allow update, delete: if isAdmin();
    }

    match /marketplaceAccounts/{accountId} {
      allow read: if resource.data.status in ["available", "reserved"] || isAdmin();
      allow write: if isAdmin();
    }

    match /topupLeads/{leadId} {
      allow create: if activeUser();
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /referralCodes/{code} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.code == code
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if signedIn()
        && (isAdmin() || resource.data.ownerUid == request.auth.uid);
    }

    match /referralRewards/{rewardId} {
      allow read: if signedIn()
        && (isAdmin() || resource.data.ownerUid == request.auth.uid || resource.data.referralUid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /bonusTransactions/{transactionId} {
      allow read: if signedIn()
        && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /chatRooms/{roomId} {
      allow read: if true;
      allow write: if activeUser();

      match /messages/{messageId} {
        allow read: if true;
        allow create: if activeUser();
        allow update: if isAdmin();
        allow delete: if isAdmin() || resource.data.uid == request.auth.uid;
      }
    }

    match /userGroups/{uid} {
      allow read: if true;
      allow create: if isAdmin()
        || (
          activeUser()
          && uid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
        );
      allow update: if isAdmin()
        || (
          activeUser()
          && uid == request.auth.uid
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
        )
        || (
          activeUser()
          && isUserGroupMember(uid)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "lastMessageText",
            "lastMessageUid",
            "lastMessageAt",
            "updatedAt"
          ])
          && request.resource.data.lastMessageUid == request.auth.uid
        );
      allow delete: if signedIn() && (isAdmin() || uid == request.auth.uid);

      match /messages/{messageId} {
        allow read: if isUserGroupMember(uid);
        allow create: if activeUser()
          && isUserGroupMember(uid)
          && request.resource.data.uid == request.auth.uid;
        allow update: if isAdmin();
        allow delete: if isAdmin() || resource.data.uid == request.auth.uid;
      }
    }

    match /directThreads/{threadId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create, update: if activeUser() && request.auth.uid in request.resource.data.participants;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/directThreads/$(threadId)).data.participants;
        allow create: if activeUser()
          && request.resource.data.uid == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/directThreads/$(threadId)).data.participants;
        allow update: if isAdmin();
        allow delete: if isAdmin() || resource.data.uid == request.auth.uid;
      }
    }

    match /clanAnnouncements/{announcementId} {
      allow read: if true;
      allow create: if activeUser()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin() || resource.data.uid == request.auth.uid;
    }

    match /forumThreads/{threadId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin() || resource.data.authorId == request.auth.uid;

      match /posts/{postId} {
        allow read: if true;
        allow create: if signedIn();
        allow update, delete: if isAdmin() || resource.data.authorId == request.auth.uid;
      }
    }

    match /crmTables/{tableId} {
      allow read, write: if isAdmin();
    }

    match /moderationQueue/{itemId} {
      allow read, write: if isAdmin();
    }

    match /siteSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /streamChats/{chatId} {
      allow read: if true;
      allow create, update: if activeUser()
        && request.resource.data.keys().hasOnly(["messages", "updatedAt"])
        && request.resource.data.messages is list
        && request.resource.data.messages.size() <= 70;
      allow delete: if isAdmin();
    }

    match /globalUserBlocks/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write, delete: if isAdmin();
    }
  }
}
